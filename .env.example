# NOAA (required for polling — include contact email)
NOAA_USER_AGENT=(indy-500-weather-panic-center, you@example.com)

# Firebase client (public — also written to public/firebase-config.json on build)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin (server + Vercel Cron — keep secret)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional topic override (default: indy-panic)
FCM_TOPIC=indy-panic

# Vercel production (Cron + live JSON storage)
CRON_SECRET=
# BLOB_READ_WRITE_TOKEN — auto-added when you link a Blob store on Vercel
